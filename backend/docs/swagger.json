                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Auth"
                ],
                "summary": "Получить тестовый JWT по роли",
                "parameters": [
                    {
                        "description": "доступны роли: admin, user",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/internal_features_auth_transport_http.DummyLoginDTO"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Тестовый токен",
                        "schema": {
                            "$ref": "#/definitions/internal_features_auth_transport_http.DummyLoginDTOResponse"
                        }
                    },
                    "400": {
                        "description": "Неверный запрос (недопустимое значение роли)",
                        "schema": {
                            "$ref": "#/definitions/github_com_tryingmyb3st_PolyTweet_internal_core_domain.CustomError"
                        }
                    },
                    "500": {
                        "description": "Внутренняя ошибка сервера",
                        "schema": {
                            "$ref": "#/definitions/github_com_tryingmyb3st_PolyTweet_internal_core_domain.InternalError"
                        }
                    }
                }
            }
        },
